# --- Python ---
# Ignore les dossiers de cache compilés
**/__pycache__/ [cite: 1, 2, 4, 10, 13]
*.py[cod] [cite: 2, 3, 4]
*$py.class

# --- Environnement Virtuel ---
# Ignore tout le dossier venv situé dans backend/
backend/venv/ 

# --- Configuration & Secrets ---
# Ignore les fichiers d'environnement (clés API, mots de passe base de données)
.env
backend/.env

# --- Base de données ---
# Ignore les fichiers de base de données SQLite si vous en utilisez
*.sqlite3
*.db

# --- Distribution / Paquets ---
# Si vous générez des dossiers de build
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --- Fichiers système & IDE ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Spécifique au projet ---
# Ignore le fichier d'arborescence lui-même si vous ne voulez pas le versionner
arbo.txt
